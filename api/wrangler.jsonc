{
  "name": "fidmem-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "development"
  },
  "secrets": [
    "TURSO_DATABASE_URL",
    "TURSO_AUTH_TOKEN",
    "NEYNAR_API_KEY",
    "BASE_RPC_URL",
    "PAYMENT_WALLET",
    "OPENAI_API_KEY"
  ]
}
